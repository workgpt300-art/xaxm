generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  balance          Float    @default(0.0)
  totalEarned      Float    @default(0.0)
  
  // Прокачка та Енергія
  clickLevel       Int      @default(1)
  energy           Float    @default(5000)
  maxEnergy        Int      @default(5000)
  lastEnergyUpdate DateTime @default(now())
  
  // Нові функції
  passiveIncome    Float    @default(0.0)
  league           String   @default("Bronze") 
  lastSpin         DateTime?
  lastCheckIn      DateTime @default(now())

  referralCode     String   @unique @default(cuid())
  referrerId       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Поле для швидкої перевірки ID виконаних завдань (потрібне для server.js)
  completedTasks   String[] @default([])

  // Зв'язки
  tasks            UserTask[]
}

model Task {
  id          String     @id @default(uuid())
  title       String     @unique
  reward      Float
  type        String     @default("SOCIAL")
  users       UserTask[]
}

model UserTask {
  id        String   @id @default(uuid())
  userId    String
  taskId    String
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id])
  @@unique([userId, taskId])
}
