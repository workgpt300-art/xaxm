// Налаштування клієнта
generator client {
  provider = "prisma-client-js"
}

// Підключення до бази
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Модель Користувача
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  password        String
  balance         Float      @default(0.0)
  role            String     @default("USER")
  
  // --- ПРОКАЧКА ТА БОНУСИ ---
  clickLevel      Int        @default(1)      // Рівень кліку (сила тапу)
  energy          Int        @default(5000)   // Встановлено 5000 енергії за замовчуванням
  maxEnergy       Int        @default(5000)   // Максимальна енергія також 5000
  lastBonusDate   DateTime?                   // Дата останнього отриманого бонусу
  
  // Реферальна система
  referrals       User[]     @relation("UserReferrals")
  referrer        User?      @relation("UserReferrals", fields: [referrerId], references: [id])
  referrerId      String?
  
  tasks           UserTask[]
  createdAt       DateTime   @default(now())
}

// Модель Завдання
model Task {
  id          String     @id @default(uuid())
  title       String     @unique
  description String?
  reward      Float
  category    String     @default("General")
  users       UserTask[]
}

// Зв'язок між користувачем і завданням
model UserTask {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  task      Task     @relation(fields: [taskId], references: [id])
  taskId    String
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  @@index([userId, taskId, createdAt])
}
