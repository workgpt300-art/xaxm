# 1. Підключення до бази даних (використовуємо дані з docker-compose)
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user_admin:password123@localhost:5432/earning_db"

# 2. Секретний ключ для JWT (використовується для шифрування токенів входу)
# Можеш змінити на будь-який набір символів
JWT_SECRET="super-secret-key-for-my-platform-2026"

# 3. Порт для сервера (на якому буде працювати твій бекенд)
PORT=5000
